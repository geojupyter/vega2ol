{
    "compilerOptions": {
      "target": "ES2020",
      "types": ["node"],
      "module": "NodeNext",
      "lib": ["DOM"],
      "declaration": true,
      "outDir": "./dist",
      "rootDir": ".",
      "strict": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "resolveJsonModule": true,
      "moduleResolution": "NodeNext"
    },
    "include": ["src/**/*", "tests/**/*.ts"],
    "exclude": ["node_modules", "dist"]
  }